{
  "expo": {
    "name": "duolingo-clone",
    "slug": "duolingo-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mascot-1024.png",
    "scheme": "duolingoclone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/mascot-1024.png",
      "bundleIdentifier": "com.anonymous.duolingo-clone",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app requires microphone access to let you practice speaking with your AI language teacher."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/mascot-welcom.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
